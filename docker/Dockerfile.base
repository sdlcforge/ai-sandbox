FROM ubuntu:latest

# === LAYER 1a: Core apt packages (no ARGs, most stable — edit last) ===
RUN apt-get update && apt-get install -y --no-install-recommends \
  ca-certificates \
  curl \
  dnsutils \
  git \
  gnupg2 \
  iproute2 \
  less \
  make \
  procps \
  python3 \
  rsync \
  ssh \
  sudo \
  unzip \
  xz-utils \
  zsh \
  && apt-get clean && rm -rf /var/lib/apt/lists/*

# === LAYER 1c: Developer/auxiliary apt packages (more likely to churn — edit here) ===
RUN apt-get update && apt-get install -y --no-install-recommends \
  aggregate \
  fzf \
  gh \
  ipset \
  iptables \
  jq \
  lsb-release \
  man-db \
  vim \
  && apt-get clean && rm -rf /var/lib/apt/lists/*

# Capability layers are appended here by docker/scripts/assemble-dockerfile.sh
# before the ENTRYPOINT line. See docker/capabilities/*.dockerfile.

# === LAYER 1d: s6-overlay (init system for graceful shutdown) ===
ARG S6_NOARCH_TAR
ARG S6_ARCH_TAR
COPY --from=tool-cache ${S6_NOARCH_TAR} /root/${S6_NOARCH_TAR}
COPY --from=tool-cache ${S6_ARCH_TAR} /root/${S6_ARCH_TAR}
RUN tar -xf /root/${S6_NOARCH_TAR} -C /
RUN tar -C / -xf /root/${S6_ARCH_TAR}
RUN rm /root/${S6_NOARCH_TAR} /root/${S6_ARCH_TAR}

# === LAYER 2: Timezone (rarely changes) ===
ARG HOST_TZ
ENV TZ="$HOST_TZ"
# Container-internal mount-parent for the host's SSH agent socket. The
# SSH_AUTH_SOCK env var itself is set at runtime in docker-compose.yaml so
# that host-agent restarts don't require an image rebuild and so BuildKit's
# secrets-in-ENV linter doesn't flag the variable name.
RUN mkdir -p /run/ai-sandbox && chmod 0755 /run/ai-sandbox

WORKDIR /root

# === LAYER 3: Go installation ===
ARG GO_TAR
COPY --from=tool-cache ${GO_TAR} /root/${GO_TAR}
RUN tar -xf ${GO_TAR} -C /usr/local && rm ${GO_TAR}
RUN ln -s /usr/local/go/bin/go /usr/local/bin/go

# === LAYER 3b: golangci-lint ===
ARG GOLANGCI_LINT_VERSION
ARG GOLANGCI_LINT_INSTALL_SH
COPY --from=tool-cache ${GOLANGCI_LINT_INSTALL_SH} /root/${GOLANGCI_LINT_INSTALL_SH}
RUN bash ${GOLANGCI_LINT_INSTALL_SH} -b /usr/local/bin ${GOLANGCI_LINT_VERSION} && rm ${GOLANGCI_LINT_INSTALL_SH}

# === LAYER 4: Git Delta ===
ARG GIT_DELTA_DEB
COPY --from=tool-cache ${GIT_DELTA_DEB} /root/${GIT_DELTA_DEB}
RUN dpkg -i ${GIT_DELTA_DEB} && rm ${GIT_DELTA_DEB}

# === LAYER 5: Zsh-in-docker (root setup) ===
ARG ZSH_IN_DOCKER_SH
COPY --from=tool-cache ${ZSH_IN_DOCKER_SH} /root/${ZSH_IN_DOCKER_SH}
RUN bash ${ZSH_IN_DOCKER_SH} -- \
  -p git \
  -p fzf \
  -a "source /usr/share/doc/fzf/examples/key-bindings.zsh" \
  -a "source /usr/share/doc/fzf/examples/completion.zsh" \
  -a "export PROMPT_COMMAND='history -a' && export HISTFILE=/commandhistory/.bash_history" \
  -x

# === LAYER 6: User creation (changes per machine) ===
ARG HOST_USER
ENV HOST_USER=${HOST_USER}
ARG HOST_HOME
ENV HOST_HOME=${HOST_HOME}
ARG HOST_UID
ARG HOST_GID
COPY scripts/create-user.sh /tmp/create-user.sh
RUN chmod +x /tmp/create-user.sh && \
    /tmp/create-user.sh "${HOST_USER}" "${HOST_HOME}" "${HOST_UID}" "${HOST_GID}" && \
    rm /tmp/create-user.sh
RUN mkdir -p /commandhistory && chown -R ${HOST_USER}:${HOST_USER} /commandhistory
RUN touch /commandhistory/.bash_history && chown -R ${HOST_USER} /commandhistory

USER ${HOST_USER}
WORKDIR ${HOST_HOME}

# === LAYER 7: NVM + Node ===
ARG NVM_INSTALL_SH
COPY --from=tool-cache ${NVM_INSTALL_SH} ${HOST_HOME}/${NVM_INSTALL_SH}
RUN bash ${NVM_INSTALL_SH} && rm ${NVM_INSTALL_SH}
RUN bash -c "source ${HOST_HOME}/.nvm/nvm.sh && nvm install --lts"

# === LAYER 8: Bun ===
ARG BUN_INSTALL_SH
COPY --from=tool-cache ${BUN_INSTALL_SH} ${HOST_HOME}/${BUN_INSTALL_SH}
RUN bash ${BUN_INSTALL_SH} && rm ${BUN_INSTALL_SH}

# === LAYER 9: Workspace & environment setup ===
RUN mkdir -p ${HOST_HOME}/playground
ENV DEVCONTAINER=true
ENV SHELL=/bin/zsh
ENV EDITOR=vim
ENV VISUAL=vim

WORKDIR ${HOST_HOME}/playground

# === LAYER 10: Claude Code (changes most frequently) ===
ARG CLAUDE_CODE_VERSION=latest
RUN ${HOST_HOME}/.bun/bin/bun install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION} && \
    { [ -e ${HOST_HOME}/.bun/bin/claude ] || \
      ln -s ${HOST_HOME}/.bun/install/global/node_modules/@anthropic-ai/claude-code/cli.js ${HOST_HOME}/.bun/bin/claude; }

# === LAYER 11: Firewall setup (root) ===
COPY init-firewall.sh /usr/local/bin/
USER root
RUN chmod +x /usr/local/bin/init-firewall.sh && \
  echo "node ALL=(root) NOPASSWD: /usr/local/bin/init-firewall.sh" > /etc/sudoers.d/node-firewall && \
  chmod 0440 /etc/sudoers.d/node-firewall

# === LAYER 11.b: Allow the user to sudo entrypoint script without a password ===
RUN usermod -aG sudo ${HOST_USER}
# RUN echo >> /etc/sudoers
# RUN echo '${HOST_USER} ALL=(ALL) NOPASSWD: /entrypoint.sh' >> /etc/sudoers
# DEBUG
RUN chmod a+r /etc/sudoers
# RUN echo "#includedir /etc/sudoers.d" >> /etc/sudoers
# RUN echo "${HOST_USER} ALL=(ALL) NOPASSWD: /entrypoint.sh" >> /etc/sudoers.d/entrypoint_script
RUN echo "${HOST_USER} ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers.d/entrypoint_script
#RUN chmod 0440 /etc/sudoers.d/entrypoint_script

# === LAYER 12: Shell config ===
USER ${HOST_USER}
RUN echo "export PATH=\$PATH:${HOST_HOME}/.bun/bin:${HOST_HOME}/.local/bin:${HOST_HOME}/go/bin" >> ${HOST_HOME}/.zshenv
# Enable 'ctrl + a', 'ctrl + e', etc.
RUN echo "bindkey -e" >> ${HOST_HOME}/.zshrc
RUN echo "PROMPT='%F{red}%~%f %# '" >> ${HOST_HOME}/.zshrc
RUN echo "source ${HOST_HOME}/.nvm/nvm.sh" >> ${HOST_HOME}/.zshrc
RUN echo "alias claude-unchained='claude --dangerously-skip-permissions'" >> ${HOST_HOME}/.zshrc
# Chromium alias is added by the chromium capability fragment (docker/capabilities/chromium.dockerfile)

# === LAYER 12b: Git config ===
ARG GIT_USER_NAME
ARG GIT_USER_EMAIL
RUN git config --global user.name "${GIT_USER_NAME}" && \
    git config --global user.email "${GIT_USER_EMAIL}"

# Disable Git's "dubious ownership" check globally inside the container.
# Not ideal: '*' trusts every path, not just the mounted playground tree.
# We tried scoping it (e.g. ${HOST_HOME}/playground/*) but Git's safe.directory
# config takes only exact paths or the literal '*' — it does not glob — and a
# more elegant per-repo solution proved difficult enough not to be worth it.
# The risk is mitigated by the container's isolation: only ~/.claude and
# ~/playground are bind-mounted from the host, network egress is allow-listed,
# and the container runs as the host user with no extra privileges.
RUN git config --global --add safe.directory '*'

# === LAYER 13: Copy claude.json (may change often) ===
COPY --from=tool-cache .claude.json ${HOST_HOME}/.claude.json

# === LAYER 14: s6-overlay scripts + sandbox-volumes helper ===
USER root
COPY rootfs/ /
RUN chmod +x /etc/cont-init.d/* /etc/cont-finish.d/* /usr/local/bin/sandbox-volumes

# Parent of the RW host-config bind (see docker-compose.isolate-config.yaml).
# Baked with 0700 root perms so non-root users can't traverse into the
# writable view of the host; `sandbox-volumes sync --match-container` reaches
# it via passwordless sudo.
RUN mkdir -p /var/lib/ai-sandbox-rw && \
    chown root:root /var/lib/ai-sandbox-rw && \
    chmod 0700 /var/lib/ai-sandbox-rw

# s6-overlay environment configuration
ENV S6_CMD_USE_TERMINAL=1
ENV S6_KILL_FINISH_MAXTIME=10000

# === LAYER 15: Build-config labels ===
# Capability-specific labels (chromium-enabled, docker-enabled) are removed
# from the base; capability state is now tracked via image tag/hash (see
# profile-installer.js). Add compose-level labels in Task 004 if needed.

# --- END OF BASE BODY ---
# The assembly script (docker/scripts/assemble-dockerfile.sh) appends capability
# fragments here, then emits:  ENTRYPOINT ["/init"]
# Do NOT add ENTRYPOINT here; it is emitted as the final line by the assembler.
# With S6-overlay, it is important to use 'docker compose exec -u ${HOST_USER} zsh'; if we add
# 'USER ${HOST_USER}' before ENTRYPOINT, then '/init' runs as that user.
