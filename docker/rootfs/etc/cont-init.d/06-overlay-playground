#!/command/with-contenv bash
# shellcheck shell=bash
# Mount an overlayfs at ${HOST_HOME}/playground so writes from inside the
# container don't propagate back to the host. The lower layer is the host's
# ~/playground, bind-mounted read-only by docker-compose.static-playground.yaml.
# The upper+work layers live on the playground-overlay named volume (unlike
# 02-overlay-config's tmpfs upper -- ~/playground is large enough that a
# RAM-backed tmpfs would be the wrong tradeoff).
#
# Skipped when AI_SANDBOX_STATIC_PLAYGROUND is unset (i.e. --static-playground
# was not passed, so docker-compose.static-playground.yaml is not in effect
# and the base compose file's read-write bind of ~/playground stands).
set -u

if [ "${AI_SANDBOX_STATIC_PLAYGROUND:-}" != "1" ]; then
  exit 0
fi

HOST_PG="${AI_SANDBOX_HOST_PLAYGROUND_DIR:-/mnt/ai-sandbox/host-playground}"
OVERLAY_ROOT="${AI_SANDBOX_PLAYGROUND_OVERLAY_DIR:-/var/lib/ai-sandbox-overlay/playground}"
UPPER="${OVERLAY_ROOT}/upper"
WORK="${OVERLAY_ROOT}/work"
TARGET="${HOST_HOME}/playground"

if [ ! -d "${HOST_PG}" ]; then
  echo "warn: host playground dir ${HOST_PG} missing; skipping playground overlay" >&2
  exit 0
fi

mkdir -p "${UPPER}" "${WORK}" "${TARGET}"
# Upper dir holds container-local writes; the running process must be able
# to write there as the host user. work/ is always root-owned and managed by
# the kernel -- no chown needed.
chown "${HOST_USER}:${HOST_USER}" "${UPPER}" "${TARGET}" 2>/dev/null || true

# Warn-and-continue (not a hard failure) on mount error: the base compose
# file's `:ro` override of ${HOST_HOME}/playground (docker-compose.static-
# playground.yaml) already leaves the container with a safe read-only view
# of the host even if this mount never happens, so there's no live-RW-
# passthrough failure mode to guard against here.
if ! mount -t overlay overlay \
      -o "lowerdir=${HOST_PG},upperdir=${UPPER},workdir=${WORK}" \
      "${TARGET}"; then
  echo "warn: overlay mount failed at ${TARGET}; host playground will be read-only" >&2
  echo "      (check CAP_SYS_ADMIN / AppArmor / kernel overlayfs support)" >&2
  exit 0
fi
echo "playground overlay mounted at ${TARGET} (copy-on-write; host is read-only)"

# Harden the RW bind's parent so only root can traverse into the writable
# view of the host. Docker auto-creates the target's parent at mount time
# with default 0755 perms, hence the defensive chmod. The bind mount target
# itself (the subdir underneath) retains the host's ownership/perms, which
# is fine -- the 0700 parent is the gate. Same hardening 02-overlay-config
# applies to its own RW bind's parent (the two share /var/lib/ai-sandbox-rw).
RW_DIR="${AI_SANDBOX_PLAYGROUND_RW_DIR:-/var/lib/ai-sandbox-rw/playground}"
RW_PARENT="$(dirname "${RW_DIR}")"
if [ -d "${RW_PARENT}" ]; then
  chown root:root "${RW_PARENT}" 2>/dev/null || true
  chmod 0700 "${RW_PARENT}" 2>/dev/null || true
fi

# Emit/refresh the sandbox-volumes registry row for this overlay. Fields are
# tab-separated: name<TAB>container_path<TAB>host_ro_mount<TAB>host_source
# <TAB>host_rw_mount.
#
# Idempotent strip-own-row-then-append pattern (not truncate-and-write): the
# registry lives on the writable layer and survives stop/start, and
# 02-overlay-config writes its own '^config\t' row to the same file. A naive
# truncate would let whichever cont-init runs later silently erase the
# other's row; a naive append would duplicate this row on every restart.
# Filtering out all '#'-prefixed lines and any existing '^playground\t' row
# before re-appending both the (re-derived, identical) header and this run's
# row keeps the file correct regardless of restart count or which overlay's
# script runs first.
HOST_SRC="${AI_SANDBOX_HOST_PLAYGROUND_SOURCE:-${HOST_HOME}/playground}"
REGISTRY="/etc/ai-sandbox/overlay-volumes.conf"
mkdir -p "$(dirname "${REGISTRY}")"
{
  printf '# Auto-generated by 02-overlay-config / 06-overlay-playground — do not edit.\n'
  printf '# Format: name<TAB>container_path<TAB>host_ro_mount<TAB>host_source<TAB>host_rw_mount\n'
  [ -f "${REGISTRY}" ] && grep -v '^#' "${REGISTRY}" | grep -v $'^playground\t'
  printf 'playground\t%s\t%s\t%s\t%s\n' "${TARGET}" "${HOST_PG}" "${HOST_SRC}" "${RW_DIR}"
} > "${REGISTRY}.tmp"
mv "${REGISTRY}.tmp" "${REGISTRY}"
chmod 0644 "${REGISTRY}"

exit 0
