#!/command/with-contenv sh
# shellcheck shell=sh
# 04-write-credentials: Write OAuth credentials into the container from the
# AI_SANDBOX_CREDENTIALS_JSON_B64 environment variable set by the host.
# This bypasses virtiofs keep_cache (which can serve stale bind-mount content)
# by receiving credentials via env var and writing them to the local filesystem.
set -u

if [ -z "${AI_SANDBOX_CREDENTIALS_JSON_B64:-}" ]; then
    exit 0
fi

mkdir -p "${HOST_HOME}/.claude"
printf '%s' "${AI_SANDBOX_CREDENTIALS_JSON_B64}" | base64 -d \
    > "${HOST_HOME}/.claude/.credentials.json"
chown "${HOST_USER}" "${HOST_HOME}/.claude/.credentials.json"
chmod 0600 "${HOST_HOME}/.claude/.credentials.json"
printf '[04-write-credentials] wrote ~/.claude/.credentials.json\n'
exit 0
