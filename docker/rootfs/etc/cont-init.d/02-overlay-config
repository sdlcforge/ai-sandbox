#!/command/with-contenv bash
# shellcheck shell=bash
# Mount an overlayfs at ${HOST_HOME}/.config so writes from inside the
# container don't propagate back to the host. The lower layer is the host's
# ~/.config, bind-mounted read-only by docker-compose.isolate-config.yaml.
# The upper+work layers live on a tmpfs (container-local, discarded with the
# container).
#
# Skipped when AI_SANDBOX_ISOLATE_CONFIG is unset (i.e. --no-isolate-config
# was passed and docker-compose.shared-config.yaml is in effect instead).
set -u

if [ "${AI_SANDBOX_ISOLATE_CONFIG:-}" != "1" ]; then
  exit 0
fi

HOST_CFG="${AI_SANDBOX_HOST_CONFIG_DIR:-/mnt/ai-sandbox/host-config}"
OVERLAY_ROOT="${AI_SANDBOX_CONFIG_OVERLAY_DIR:-/run/ai-sandbox/config-overlay}"
UPPER="${OVERLAY_ROOT}/upper"
WORK="${OVERLAY_ROOT}/work"
TARGET="${HOST_HOME}/.config"

if [ ! -d "${HOST_CFG}" ]; then
  echo "warn: host config dir ${HOST_CFG} missing; skipping config overlay" >&2
  exit 0
fi

mkdir -p "${UPPER}" "${WORK}" "${TARGET}"
# Upper dir holds container-local copies; the running process must be able to
# write there as the host user. work/ is always root-owned and managed by the
# kernel — no chown needed.
chown "${HOST_USER}:${HOST_USER}" "${UPPER}" "${TARGET}" 2>/dev/null || true

if ! mount -t overlay overlay \
      -o "lowerdir=${HOST_CFG},upperdir=${UPPER},workdir=${WORK}" \
      "${TARGET}"; then
  echo "warn: overlay mount failed at ${TARGET}; host .config will not be visible" >&2
  echo "      (check CAP_SYS_ADMIN / AppArmor / kernel overlayfs support)" >&2
  exit 0
fi
echo "config overlay mounted at ${TARGET} (copy-on-write; host is read-only)"

# Harden the RW bind's parent so only root can traverse into the writable
# view of the host. Docker auto-creates the target's parent at mount time
# with default 0755 perms, hence the defensive chmod. The bind mount target
# itself (the subdir underneath) retains the host's ownership/perms, which
# is fine — the 0700 parent is the gate.
RW_DIR="${AI_SANDBOX_CONFIG_RW_DIR:-/var/lib/ai-sandbox-rw/config}"
RW_PARENT="$(dirname "${RW_DIR}")"
if [ -d "${RW_PARENT}" ]; then
  chown root:root "${RW_PARENT}" 2>/dev/null || true
  chmod 0700 "${RW_PARENT}" 2>/dev/null || true
fi

# Emit the sandbox-volumes registry so that tool can find each overlay.
# Fields are tab-separated: name<TAB>container_path<TAB>host_ro_mount<TAB>
# host_source<TAB>host_rw_mount.
HOST_SRC="${AI_SANDBOX_HOST_CONFIG_SOURCE:-${HOST_HOME}/.config}"
REGISTRY="/etc/ai-sandbox/overlay-volumes.conf"
mkdir -p "$(dirname "${REGISTRY}")"
{
  printf '# Auto-generated by 02-overlay-config — do not edit.\n'
  printf '# Format: name<TAB>container_path<TAB>host_ro_mount<TAB>host_source<TAB>host_rw_mount\n'
  printf 'config\t%s\t%s\t%s\t%s\n' "${TARGET}" "${HOST_CFG}" "${HOST_SRC}" "${RW_DIR}"
} > "${REGISTRY}"
chmod 0644 "${REGISTRY}"

exit 0
