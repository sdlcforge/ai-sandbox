#!/command/with-contenv sh
# shellcheck shell=sh
# 10-plugin-setup: Register Claude Code marketplaces and enable plugins at
# container start. Reads AI_SANDBOX_MARKETPLACES and AI_SANDBOX_PLUGINS
# (pipe-separated to avoid collisions with colons in URLs), and
# AI_SANDBOX_ENABLE_ALL_PLUGINS (true/false).
# Idempotent and non-fatal — warns on errors but never blocks container startup.
set -u

if [ -z "${AI_SANDBOX_MARKETPLACES:-}" ] && [ -z "${AI_SANDBOX_PLUGINS:-}" ]; then
    exit 0
fi

# claude lives under the host user's bun install; not on root's PATH.
CLAUDE_BIN="${HOST_HOME}/.bun/bin/claude"
if [ ! -x "${CLAUDE_BIN}" ]; then
    printf '[10-plugin-setup] warn: claude not found at %s; skipping plugin setup\n' \
        "${CLAUDE_BIN}" >&2
    exit 0
fi

# Run plugin commands as the host user so ~/.claude resolves to the bind-mounted
# directory and files are written with the correct ownership.
_run() { /command/s6-setuidgid "${HOST_USER}" env HOME="${HOST_HOME}" "$@"; }

# Register marketplaces (pipe-separated).
if [ -n "${AI_SANDBOX_MARKETPLACES:-}" ]; then
    _copy="${AI_SANDBOX_MARKETPLACES}"
    while [ -n "${_copy}" ]; do
        _mp="${_copy%%|*}"
        if [ "${_mp}" = "${_copy}" ]; then
            _copy=""
        else
            _copy="${_copy#*|}"
        fi
        [ -z "${_mp}" ] && continue

        # claude plugins marketplace add accepts bare absolute paths and https://
        # URLs, but not file:// URIs — strip the scheme when present.
        case "${_mp}" in
            file://*) _mp_add="${_mp#file://}" ;;
            *)        _mp_add="${_mp}" ;;
        esac

        if _run "${CLAUDE_BIN}" plugins marketplace list 2>/dev/null | grep -qF "${_mp_add}"; then
            printf '[10-plugin-setup] marketplace already registered: %s\n' "${_mp}"
        else
            printf '[10-plugin-setup] registering marketplace: %s\n' "${_mp}"
            _run "${CLAUDE_BIN}" plugins marketplace add "${_mp_add}" 2>&1 \
                || printf '[10-plugin-setup] warn: failed to register marketplace: %s\n' \
                    "${_mp}" >&2
        fi
    done
fi

# Install (and thereby enable) individual plugins (pipe-separated). "install"
# is used rather than "enable" because "enable" only works on a plugin that is
# already installed but currently disabled -- a plugin named solely via
# --enable-plugin has never been installed, so "enable" always fails for it.
if [ -n "${AI_SANDBOX_PLUGINS:-}" ]; then
    _copy="${AI_SANDBOX_PLUGINS}"
    while [ -n "${_copy}" ]; do
        _plugin="${_copy%%|*}"
        if [ "${_plugin}" = "${_copy}" ]; then
            _copy=""
        else
            _copy="${_copy#*|}"
        fi
        [ -z "${_plugin}" ] && continue

        if _run "${CLAUDE_BIN}" plugins list 2>/dev/null | grep -qF "${_plugin}"; then
            printf '[10-plugin-setup] plugin already enabled: %s\n' "${_plugin}"
        else
            printf '[10-plugin-setup] enabling plugin: %s\n' "${_plugin}"
            _run "${CLAUDE_BIN}" plugins install "${_plugin}" 2>&1 \
                || printf '[10-plugin-setup] warn: failed to enable plugin: %s\n' \
                    "${_plugin}" >&2
        fi
    done
fi

# Install all plugins from registered file:// marketplaces if requested.
# claude has no --all flag for enable or install; read each manifest and
# install plugins individually.
if [ "${AI_SANDBOX_ENABLE_ALL_PLUGINS:-false}" = "true" ]; then
    if [ -z "${AI_SANDBOX_MARKETPLACES:-}" ]; then
        printf '[10-plugin-setup] warn: enable-all set but no marketplace was configured\n' >&2
    else
        _copy="${AI_SANDBOX_MARKETPLACES}"
        while [ -n "${_copy}" ]; do
            _mp="${_copy%%|*}"
            if [ "${_mp}" = "${_copy}" ]; then _copy=""; else _copy="${_copy#*|}"; fi
            [ -z "${_mp}" ] && continue

            case "${_mp}" in
                file://*) _manifest="${_mp#file://}" ;;
                *)
                    printf '[10-plugin-setup] warn: enable-all not supported for non-file marketplace: %s\n' \
                        "${_mp}" >&2
                    continue
                    ;;
            esac

            if [ ! -f "${_manifest}" ]; then
                printf '[10-plugin-setup] warn: marketplace manifest not found: %s\n' \
                    "${_manifest}" >&2
                continue
            fi

            _mp_name=$(jq -r '.name // ""' "${_manifest}" 2>/dev/null)
            printf '[10-plugin-setup] installing all plugins from: %s\n' "${_mp}"

            jq -r '.plugins[].name' "${_manifest}" 2>/dev/null \
            | while IFS= read -r _plugin_name; do
                [ -z "${_plugin_name}" ] && continue
                _plugin_ref="${_plugin_name}@${_mp_name}"
                if _run "${CLAUDE_BIN}" plugins list 2>/dev/null | grep -qF "${_plugin_name}"; then
                    printf '[10-plugin-setup] plugin already installed: %s\n' "${_plugin_ref}"
                else
                    printf '[10-plugin-setup] installing plugin: %s\n' "${_plugin_ref}"
                    _run "${CLAUDE_BIN}" plugins install "${_plugin_ref}" 2>&1 \
                        || printf '[10-plugin-setup] warn: failed to install plugin: %s\n' \
                            "${_plugin_ref}" >&2
                fi
            done
        done
    fi
fi

exit 0
