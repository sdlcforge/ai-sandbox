#!/bin/bash
# sandbox-volumes — inspect and sync overlay-mounted volumes in ai-sandbox.
#
# Reads /etc/ai-sandbox/overlay-volumes.conf (generated by the
# 02-overlay-config cont-init script) for the list of volumes mounted as
# copy-on-write overlays inside this container. For each volume there are
# three paths of interest:
#   * container   — the overlay mount point (what the user sees / writes to)
#   * host RO     — read-only bind of the host source, used as the overlay
#                   lower layer; readable to everyone
#   * host RW     — read-write bind of the host source; parent dir is 0700
#                   root, so only sudo can reach it. Used for `sync
#                   --match-container` to push container state back to host.
#
# In --no-isolate-config mode the registry is absent and every command is a
# no-op (list/status print nothing; diff/sync fail with a clear message).

set -euo pipefail

REGISTRY="${SANDBOX_VOLUMES_REGISTRY:-/etc/ai-sandbox/overlay-volumes.conf}"

die() { printf 'sandbox-volumes: %s\n' "$*" >&2; exit 1; }

usage() {
    cat <<'EOF'
Usage: sandbox-volumes <command> [args]

Commands:
  list                               List overlay-mounted volumes.
  status [<path>]                    Report drift between container and host.
                                     With no <path>, all volumes are checked.
  diff <path> [-- <diff-args>...]    Show a diff of <path> between container
                                     and host views. Args after '--' pass
                                     through to diff(1).
  sync <direction> [flags] <path>    Copy <path> one direction.
      <direction>                    --match-host   (host → container)
                                     --match-container (container → host;
                                                        uses passwordless sudo)
      [flags]                        --delete     propagate deletions
                                     --dry-run    show without writing

<path> may be an absolute path inside the container, under $HOME, or any
prefix of a registered volume's container path — it's resolved to the
volume it lives in plus a relative subpath.

Help: sandbox-volumes --help
EOF
}

# Load the registry into parallel arrays keyed by volume name.
declare -a VOL_NAMES=()
declare -A VOL_CP=() VOL_RO=() VOL_SRC=() VOL_RW=()
load_registry() {
    [ -r "$REGISTRY" ] || return 0
    local name cp ro src rw
    while IFS=$'\t' read -r name cp ro src rw; do
        case "$name" in '' | \#*) continue ;; esac
        VOL_NAMES+=("$name")
        VOL_CP[$name]="$cp"
        VOL_RO[$name]="$ro"
        VOL_SRC[$name]="$src"
        VOL_RW[$name]="$rw"
    done < "$REGISTRY"
}

# Normalize a user-supplied path to an absolute one without requiring it to
# exist (readlink -f does the right thing for existing paths; for missing
# paths we fall back to $PWD-based resolution).
_normalize_path() {
    local input="$1" abs
    if [ -e "$input" ]; then
        abs="$(readlink -f "$input")"
    else
        case "$input" in
            /*) abs="$input" ;;
            *)  abs="$PWD/$input" ;;
        esac
    fi
    abs="${abs%/}"
    printf '%s\n' "${abs:-/}"
}

# Resolve a filesystem path to its owning volume and relative subpath.
# Writes 'NAME<TAB>REL' to stdout. Dies if the path isn't under any
# registered volume (REL is '.' when the path is exactly the volume root).
resolve_path() {
    local input="$1"
    local abs
    abs="$(_normalize_path "$input")"
    local name cp
    for name in "${VOL_NAMES[@]}"; do
        cp="${VOL_CP[$name]}"
        if [ "$abs" = "$cp" ]; then
            printf '%s\t.\n' "$name"
            return 0
        fi
        case "$abs/" in
            "$cp"/*)
                printf '%s\t%s\n' "$name" "${abs#"$cp/"}"
                return 0
                ;;
        esac
    done
    die "path '$input' is not under any registered overlay volume"
}

cmd_list() {
    [ "${#VOL_NAMES[@]}" -eq 0 ] && return 0
    printf '%-12s %-40s %s\n' 'NAME' 'CONTAINER' 'HOST'
    local name
    for name in "${VOL_NAMES[@]}"; do
        printf '%-12s %-40s %s\n' "$name" "${VOL_CP[$name]}" "${VOL_SRC[$name]}"
    done
}

# diff -qr exit codes: 0 identical, 1 differ, 2 error. We treat 0/1 as
# "answered the question" and anything else as a real error.
_count_differences() {
    local ro="$1" cp="$2" out
    out="$(diff -qr "$ro" "$cp" 2>/dev/null || true)"
    if [ -z "$out" ]; then
        printf '0\n'
    else
        printf '%s\n' "$out" | wc -l
    fi
}

cmd_status() {
    if [ "${#VOL_NAMES[@]}" -eq 0 ]; then
        echo "no overlay volumes (running with --no-isolate-config?)" >&2
        return 0
    fi
    local rc=0 targets=() name n
    if [ $# -gt 0 ]; then
        IFS=$'\t' read -r name _rel < <(resolve_path "$1")
        targets=("$name")
    else
        targets=("${VOL_NAMES[@]}")
    fi
    for name in "${targets[@]}"; do
        n="$(_count_differences "${VOL_RO[$name]}" "${VOL_CP[$name]}")"
        if [ "$n" = "0" ]; then
            printf '%s\tclean\n' "$name"
        else
            printf '%s\tdrift (%s differing paths)\n' "$name" "$n"
            rc=1
        fi
    done
    return "$rc"
}

cmd_diff() {
    [ $# -ge 1 ] || die "diff requires a path (see --help)"
    local path="$1"; shift
    local diff_args=()
    if [ "${1:-}" = "--" ]; then
        shift
        diff_args=("$@")
    elif [ $# -gt 0 ]; then
        die "unexpected args after path; pass diff(1) options after '--'"
    fi
    [ "${#VOL_NAMES[@]}" -gt 0 ] || die "no overlay volumes registered"
    local name rel
    IFS=$'\t' read -r name rel < <(resolve_path "$path")
    local ro="${VOL_RO[$name]}" cp="${VOL_CP[$name]}"
    local a b
    if [ "$rel" = "." ]; then
        a="$ro"; b="$cp"
    else
        a="$ro/$rel"; b="$cp/$rel"
    fi
    # diff exits 1 when differences are found — expected, not an error.
    diff -ur "${diff_args[@]}" "$a" "$b" || [ $? -eq 1 ]
}

cmd_sync() {
    local direction="" rsync_delete="" rsync_dry=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --match-host)       direction=host ;;
            --match-container)  direction=container ;;
            --delete)           rsync_delete="--delete" ;;
            --dry-run)          rsync_dry="--dry-run" ;;
            --) shift; break ;;
            --*) die "unknown flag: $1 (see --help)" ;;
            *)  break ;;
        esac
        shift
    done
    [ -n "$direction" ] || die "sync requires --match-host or --match-container"
    [ $# -eq 1 ] || die "sync requires exactly one <path>"
    [ "${#VOL_NAMES[@]}" -gt 0 ] || die "no overlay volumes registered"
    local name rel
    IFS=$'\t' read -r name rel < <(resolve_path "$1")
    local cp="${VOL_CP[$name]}" ro="${VOL_RO[$name]}" rw="${VOL_RW[$name]}"
    local src_base dst_base sudo_cmd=""
    if [ "$direction" = "host" ]; then
        src_base="$ro"
        dst_base="$cp"
    else
        src_base="$cp"
        dst_base="$rw"
        sudo_cmd="sudo"
    fi
    local src dst
    if [ "$rel" = "." ]; then
        src="$src_base/"
        dst="$dst_base/"
    else
        src="$src_base/$rel"
        dst="$dst_base/$rel"
        if [ -z "$rsync_dry" ]; then
            $sudo_cmd mkdir -p "${dst%/*}"
        fi
    fi
    if [ -d "$src" ] && [ "${src: -1}" != "/" ]; then
        src="$src/"
    fi
    if [ -d "$dst" ] && [ "${dst: -1}" != "/" ]; then
        dst="$dst/"
    fi
    printf 'sandbox-volumes: sync %s%s%s\n  %s\n  -> %s\n' \
        "$direction" \
        "${rsync_delete:+ (--delete)}" \
        "${rsync_dry:+ [dry-run]}" \
        "$src" "$dst"
    # shellcheck disable=SC2086 # intentional word-splitting for optional flags
    $sudo_cmd rsync -a --itemize-changes $rsync_delete $rsync_dry "$src" "$dst"
}

main() {
    [ $# -eq 0 ] && { usage; exit 0; }
    local cmd="$1"; shift
    load_registry
    case "$cmd" in
        list)                cmd_list "$@" ;;
        status)              cmd_status "$@" ;;
        diff)                cmd_diff "$@" ;;
        sync)                cmd_sync "$@" ;;
        -h|--help|help)      usage ;;
        *)                   die "unknown command: $cmd (try --help)" ;;
    esac
}

main "$@"
